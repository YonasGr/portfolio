---
import { Icon } from 'astro-icon/components';
import localData from '../data/home.json';

//Data Definitions
interface Social {
  name: string;
  url: string;
  icon: string;
}

interface ProfileData {
  name: string;
  photoUrl: string;
  intro: string;
  introHtml: string;
  resumeUrl: string;
  socials: Social[];
}

const isApiLive = import.meta.env.PROD; // Auto true in production
const BASE_URL = import.meta.env.PUBLIC_API_BASE_URL;

let data: ProfileData; // data as ProfileData

if (isApiLive && BASE_URL) {
  try {
    const response = await fetch(`${BASE_URL}/home`);
    if (!response.ok) throw new Error('Network response was not ok');
    data = await response.json();
  } catch (error) {
    console.error("API Fetch failed, falling back to mock data", error);
    data = localData as ProfileData;
  }
} else {
  data = localData as ProfileData;
}

const { name, intro, introHtml, resumeUrl, socials } = data;
---

<section id="home" class="flex flex-col md:flex-row min-h-[80vh] md:min-h-screen md:pt-20">
  <div class="w-full md:w-[44%] md:h-screen relative overflow-hidden">
    <img
      src="/branding-poster.png"
      alt="Branding poster"
      class="w-full h-full object-cover object-[50%_15%]"
      loading="lazy"
    />
    <div class="absolute inset-y-0 right-0 w-16 bg-gradient-to-l from-black/35 to-transparent pointer-events-none"></div>
  </div>

  <div class="w-full md:w-[56%] flex flex-col items-center md:items-start justify-center px-6 sm:px-10 md:px-16 lg:px-20 py-12 md:py-0 relative">
    <div class="hidden md:block absolute left-8 top-12 bottom-12 w-px bg-accent/20"></div>

    <div class="reveal-content md:pl-6" style="animation-delay: 100ms;">
      <p class="font-body font-light text-gray leading-relaxed text-center md:text-left">
        Hello, I'm
      </p>
    </div>

    <div class="px-6 sm:px-14 md:px-0 max-w-360 mx-auto md:mx-0 relative z-0 reveal-content md:pl-6" style="animation-delay: 200ms;">
      <h1 class="text-5xl md:text-7xl font-heading font-bold text-maintext tracking-tight text-center md:text-left">
        {name}
      </h1>
      <br>
      <p 
        class="text-gray font-body text-lg leading-relaxed text-center md:text-left" 
        set:html={intro} 
      />
    </div>

    <div class="mt-8 mb-4 reveal-content md:pl-6" style="animation-delay: 300ms;">
      <a 
        href={resumeUrl} 
        target="_blank" 
        rel="noopener noreferrer"
        class="group relative inline-flex items-center justify-center px-10 py-2 bg-white/5 border border-white/10 rounded-full text-maintext font-body transition-all duration-300

               border-accent/50 bg-accent/10 shadow-[0_0_20px_rgba(var(--accent-rgb),0.3)]
               
               md:border-accent/50 md:bg-accent/10 md:shadow-none md:hover:border-accent/50 md:hover:bg-accent/10 md:hover:shadow-[0_0_20px_rgba(var(--accent-rgb),0.3)] 
               hover:scale-105"
      >
        <div class="flex flex-col items-center justify-center text-center">
          <span class="tracking-wide text-sm md:text-base font-medium transition-transform duration-300 md:translate-y-2 md:group-hover:translate-y-0">
            View Resume
          </span>
          
          <span class="text-[10px] text-subtext font-light whitespace-nowrap transition-all duration-300 
                       opacity-100 translate-y-0 
                       md:opacity-0 md:translate-y-1 md:group-hover:opacity-100 md:group-hover:translate-y-0">
            Downloads PDF file
          </span>
        </div>
        
        <div class="absolute inset-0 rounded-full blur-md bg-accent/20 -z-10 opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-opacity duration-500"></div>
      </a>
    </div>

    <div class="flex gap-6 mt-4 reveal-content md:pl-6" style="animation-delay: 400ms;">
      {socials.filter((social) => social.url && social.url !== "#" && social.url !== "").map((social) => (
        <a 
          href={social.url} 
          target="_blank" 
          class="group relative flex flex-col items-center justify-center transition-all duration-300 hover:scale-110"
        >
          <Icon 
          name={social.icon} 
          class="w-8 h-8 text-maintext group-hover:text-accent transition-colors duration-300" 
        />

        <span class="absolute -bottom-6 scale-0 opacity-0 group-hover:scale-100 group-hover:opacity-100 transition-all duration-300 text-xs text-accent font-body">
          {social.name}
        </span>
        </a>
      ))}
    </div>
  </div>
</section>


<style is:global>
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  @keyframes revealIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
