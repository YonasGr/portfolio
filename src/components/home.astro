---
import { Icon } from 'astro-icon/components';
import localData from '../data/home.json';
import { Image } from 'astro:assets';
import brandingPoster from '../assets/branding-poster.png';

//Data Definitions
interface Social {
  name: string;
  url: string;
  icon: string;
}

interface ProfileData {
  name: string;
  photoUrl: string;
  intro: string;
  introHtml: string;
  resumeUrl: string;
  socials: Social[];
}

const isApiLive = import.meta.env.PROD; // Auto true in production
const BASE_URL = import.meta.env.PUBLIC_API_BASE_URL;

let data: ProfileData; // data as ProfileData

if (isApiLive && BASE_URL) {
  try {
    const response = await fetch(`${BASE_URL}/home`);
    if (!response.ok) throw new Error('Network response was not ok');
    data = await response.json();
  } catch (error) {
    console.error("API Fetch failed, falling back to mock data", error);
    data = localData as ProfileData;
  }
} else {
  data = localData as ProfileData;
}

const { name, intro, resumeUrl, socials } = data;

const techStack = [
  { name: 'React', note: 'Component-driven UI', x: '8%', y: '15%', rotation: '-5deg', color: 'text-blue-500' },
  { name: 'Python', note: 'Backend logic', x: '88%', y: '12%', rotation: '3deg', color: 'text-yellow-600' },
  { name: 'Tailwind', note: 'Modern styling', x: '12%', y: '82%', rotation: '2deg', color: 'text-teal-500' },
  { name: 'Docker', note: 'Containerization', x: '85%', y: '78%', rotation: '-4deg', color: 'text-blue-600' },
];
---

<section id="home" class="min-h-screen relative overflow-hidden paper-texture flex flex-col items-center justify-center pt-24 pb-12">
  <!-- Background Decorations -->
  <div class="absolute inset-0 pointer-events-none opacity-20">
    <div class="absolute top-20 left-10 w-64 h-64 bg-blue-400/20 blur-3xl"></div>
    <div class="absolute bottom-20 right-10 w-64 h-64 bg-purple-400/20 blur-3xl"></div>

    <!-- Pencil Lines -->
    <svg class="absolute inset-0 w-full h-full text-gray-300" xmlns="http://www.w3.org/2000/svg">
      <path d="M-100 100 Q 500 50 1200 150" fill="none" stroke="currentColor" stroke-width="0.5" stroke-dasharray="5 5" />
      <path d="M1200 800 Q 600 850 -100 750" fill="none" stroke="currentColor" stroke-width="0.5" stroke-dasharray="5 5" />
    </svg>
  </div>

  <div class="container mx-auto px-6 relative z-10 flex flex-col items-center">

    <!-- Hero Title & Intro -->
    <div class="text-center mb-12 reveal-content" style="animation-delay: 100ms;">
      <p class="font-sketch text-2xl text-gray-600 mb-2 rotate-[-1deg]">
        Hello, I'm
      </p>
      <h1 class="text-6xl md:text-8xl font-heading font-bold text-gray-900 tracking-tight mb-6">
        {name}
      </h1>
      <p
        class="text-gray-700 font-body text-xl leading-relaxed max-w-2xl mx-auto"
        set:html={intro}
      />
    </div>

    <!-- Central Poster Spread -->
    <div class="relative w-full max-w-4xl reveal-content" style="animation-delay: 300ms;">

      <!-- Hand-drawn Annotations (Desktop Only) -->
      <div class="hidden lg:block">
        {techStack.map((tech) => (
          <div
            class="absolute z-20 group"
            style={`left: ${tech.x}; top: ${tech.y}; transform: rotate(${tech.rotation});`}
          >
            <div class="font-sketch bg-white/90 backdrop-blur-sm px-4 py-2 sketch-border shadow-sm text-sm whitespace-nowrap transform group-hover:scale-110 transition-transform">
              <span class={`font-bold ${tech.color}`}>{tech.name}:</span> {tech.note}
            </div>
            <!-- Hand-drawn style arrow replacement -->
            <div class={`w-12 h-12 ${tech.x.includes('8') ? 'scale-x-[-1] ml-auto' : ''} opacity-40 mt-1`}>
               <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                 <path d="M20 20 Q 50 10 80 50" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="text-gray-400"/>
               </svg>
            </div>
          </div>
        ))}
      </div>

      <!-- The Branding Poster -->
      <div class="relative z-10 sketch-border bg-white p-2 md:p-6 shadow-2xl transform rotate-[0.5deg] hover:rotate-0 transition-transform duration-700">
        <div class="relative overflow-hidden rounded-sm">
          <Image
            src={brandingPoster}
            alt={name}
            class="w-full h-auto grayscale-[0.1] hover:grayscale-0 transition-all duration-1000"
            loading="eager"
          />
        </div>
      </div>

      <!-- Decorative Tape / Clips -->
      <div class="absolute -top-4 left-1/2 -translate-x-1/2 w-32 h-8 bg-gray-200/50 backdrop-blur-sm rotate-1 z-20 border border-white/20"></div>
    </div>

    <!-- Action Buttons -->
    <div class="mt-16 flex flex-col sm:flex-row gap-6 items-center reveal-content" style="animation-delay: 500ms;">
      <a
        href={resumeUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="group relative inline-flex items-center justify-center px-10 py-3 bg-gray-900 text-white rounded-full font-body font-medium transition-all duration-300 hover:scale-105 hover:shadow-xl overflow-hidden"
      >
        <span class="relative z-10 flex items-center gap-2">
          View Resume
          <Icon name="mdi:arrow-right" class="w-5 h-5 group-hover:translate-x-1 transition-transform" />
        </span>
        <div class="absolute inset-0 bg-accent/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
      </a>

      <!-- Social Links -->
      <div class="flex gap-6">
        {socials.filter((social) => social.url && social.url !== "#" && social.url !== "").map((social) => (
          <a
            href={social.url}
            target="_blank"
            class="group relative p-3 text-gray-600 hover:text-gray-900 transition-all duration-300 hover:scale-110 bg-white/50 sketch-border"
            title={social.name}
          >
            <Icon
              name={social.icon}
              class="w-6 h-6"
            />
          </a>
        ))}
      </div>
    </div>

  </div>

  <!-- Scroll Indicator (Doodle Style) -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 opacity-40 reveal-content" style="animation-delay: 700ms;">
    <div class="flex flex-col items-center gap-2">
      <span class="font-sketch text-xs text-gray-500">Scroll to Explore</span>
      <div class="w-0.5 h-12 bg-gradient-to-b from-gray-400 to-transparent"></div>
    </div>
  </div>
</section>

<style is:global>
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  @keyframes revealIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Paper Texture Reinforcement for Hero */
  .paper-texture {
    background-color: #fcfcfc;
    color: #1a1c1c;
  }
</style>
