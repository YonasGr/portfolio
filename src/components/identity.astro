---
import { Image } from 'astro:assets';
import brandingPoster from '../assets/branding-poster.png';

const techStack = [
  { name: 'React', note: 'Component-driven UI', x: '10%', y: '20%', rotation: '-5deg' },
  { name: 'Next.js', note: 'SSR & App Router', x: '85%', y: '15%', rotation: '3deg' },
  { name: 'Tailwind CSS', note: 'Utility-first styling', x: '15%', y: '75%', rotation: '2deg' },
  { name: 'Python', note: 'Backend logic', x: '80%', y: '80%', rotation: '-4deg' },
];
---

<section id="identity" class="py-24 relative overflow-hidden paper-texture">
  <!-- Section Title -->
  <div class="max-w-7xl mx-auto px-6 mb-16 text-center relative z-10">
    <h2 class="text-4xl md:text-5xl font-heading font-bold text-gray-900 mb-4">
      The Creative Process
    </h2>
    <p class="font-sketch text-xl text-gray-700 max-w-2xl mx-auto -rotate-1">
      "Merging technical precision with artistic exploration."
    </p>
  </div>

  <div class="max-w-5xl mx-auto px-6 relative">
    <!-- Branding Poster Container -->
    <div class="relative z-10 sketch-border bg-white p-4 md:p-8 shadow-xl transform hover:rotate-1 transition-transform duration-500">
      <div class="relative overflow-hidden rounded-sm">
        <Image
          src={brandingPoster}
          alt="Personal Branding Poster - Sketchbook Style"
          class="w-full h-auto grayscale-[0.2] hover:grayscale-0 transition-all duration-700"
        />

        <!-- Watercolor Overlays -->
        <div class="absolute top-0 left-0 w-64 h-64 bg-blue-400/10 blur-3xl pointer-events-none"></div>
        <div class="absolute bottom-0 right-0 w-64 h-64 bg-purple-400/10 blur-3xl pointer-events-none"></div>
      </div>

      <!-- Annotations (Visible on Desktop) -->
      <div class="hidden lg:block">
        {techStack.map((tech) => (
          <div
            class="absolute pointer-events-none"
            style={`left: ${tech.x}; top: ${tech.y}; transform: rotate(${tech.rotation});`}
          >
            <div class="font-sketch text-gray-800 bg-yellow-100/80 px-3 py-1 rounded-sm shadow-sm border border-black/10 text-sm whitespace-nowrap">
              {tech.note}
            </div>
            <!-- Wobbly Arrow (CSS implementation) -->
            <div class="w-12 h-0.5 bg-gray-800/30 origin-left mt-2 -ml-4 rotate-45"></div>
          </div>
        ))}
      </div>
    </div>

    <!-- Background Doodles -->
    <div class="absolute top-[-10%] left-[-5%] opacity-20 pointer-events-none">
       <svg width="200" height="200" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
         <path d="M40 100C40 100 60 40 100 40C140 40 160 100 160 100C160 100 140 160 100 160C60 160 40 100 40 100Z" stroke="currentColor" stroke-width="2" class="text-blue-500"/>
         <circle cx="100" cy="100" r="20" stroke="currentColor" stroke-width="2" class="text-purple-500"/>
       </svg>
    </div>

    <div class="absolute bottom-[-5%] right-[-5%] opacity-20 pointer-events-none">
       <svg width="150" height="150" viewBox="0 0 150 150" fill="none" xmlns="http://www.w3.org/2000/svg">
         <path d="M20 20L130 130M130 20L20 130" stroke="currentColor" stroke-width="4" stroke-linecap="round" class="text-gray-400"/>
       </svg>
    </div>
  </div>

  <!-- Mobile Annotations -->
  <div class="lg:hidden max-w-xl mx-auto px-6 mt-12 grid grid-cols-2 gap-4">
    {techStack.map((tech) => (
      <div class="font-sketch text-gray-700 bg-white/50 p-3 rounded border border-gray-200">
        <span class="font-bold text-gray-900">{tech.name}:</span> {tech.note}
      </div>
    ))}
  </div>
</section>

<style>
  .paper-texture {
    /* Reinforce theme colors for light section */
    --tw-text-opacity: 1;
    color: rgb(31 41 55 / var(--tw-text-opacity));
  }
</style>
